#!/bin/bash

export TERM="tmux-256color"
export EDITOR="nvim"

export PROJECTS="$HOME/com.github"
export DOTFILES="$PROJECTS/dotfiles/main"
export ICLOUD="$HOME/Library/Mobile\ Documents/com~apple~CloudDocs"
export BRAIN="$HOME/Documents/Notes"

export FZF_DEFAULT_OPTS="--tiebreak=length,begin,index"

# Custom aliases
if [ -n "$(find "$XDG_CONFIG_HOME/shell/aliases/" -maxdepth 1 -type f -not \( -name '.' -o -name '..' \))" ]; then
  for file in "$XDG_CONFIG_HOME/shell/aliases/"*; do
    if [ -f "$file" ]; then
      source "$file"
    fi
  done
fi

export PATH="$HOME/.local/bin:$DOTFILES/bin:$PATH"

# Work specific shell configuration
if [ -f "$XDG_CONFIG_HOME/shell/work" ]; then
  source "$XDG_CONFIG_HOME/shell/work"
fi

# Golang
export GOPATH="$HOME/go"
export GOBIN="$GOPATH/bin"
export PATH="$GOBIN:$PATH"

eval "$(zoxide init zsh)"
source <(fzf --zsh)

# If rbenv is installed, initialize it
if command -v rbenv >/dev/null 2>&1; then
  eval "$(rbenv init - --no-rehash zsh)"
fi

# Drive tmux window renaming from shell hooks instead of tmux's #() format
# strings, which run asynchronously and can leak output to new panes.
if [ -n "$TMUX" ]; then
  _tmux_rename_preexec() {
    tmux rename-window "$(tmux_window_name "$1")" 2>/dev/null
  }
  _tmux_rename_precmd() {
    while IFS=' ' read -r pane_id pane_cmd; do
      [[ "$pane_id" == "$TMUX_PANE" ]] && continue
      local icon
      icon="$(tmux_window_name "$pane_cmd")"

      # Do not rename the window if there's another Pane that already did it
      [[ "$icon" != "" ]] && return
    done < <(tmux list-panes -F '#{pane_id} #{pane_current_command}' 2>/dev/null)
    tmux rename-window "$(tmux_window_name zsh)" 2>/dev/null
  }
  add-zsh-hook preexec _tmux_rename_preexec
  add-zsh-hook precmd _tmux_rename_precmd
fi
