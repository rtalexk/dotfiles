#!/usr/bin/env bash

# Drop omz aliases
unalias ggpush 2>/dev/null
unalias gca! 2>/dev/null

# Git aliases
alias difon="git diff --name-only origin/main"
alias difo="git diff origin/main"
alias grsf="git reset --soft"
alias gcwip='git rm $(git ls-files --deleted) 2> /dev/null; git commit --no-verify --no-gpg-sign --message "--wip-- [skip ci]"'
alias gbdm="git branch --merged | egrep -v '(^\*|master|main|dev)' | xargs git branch -d"
alias gsta='git stash push --include-untracked'
alias gca!='git commit --amend --no-edit --no-verify'

gpush() {
  local arg bundle flags=()
  for arg in "$@"; do
    if [[ $arg =~ '^-?[ufn]+$' ]]; then
      bundle=${arg#-}
      [[ $bundle == *u* ]] && flags+=(--set-upstream)
      [[ $bundle == *f* ]] && flags+=(--force-with-lease --force-if-includes)
      [[ $bundle == *n* ]] && flags+=(--no-verify)
    else
      flags+=("$arg")
    fi
  done
  git push "${flags[@]}" origin "$(git_current_branch)"
}

alias git-bare='git --git-dir=.bare --work-tree=.'
