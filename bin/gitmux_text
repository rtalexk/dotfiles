#!/usr/bin/env bash

if [ -z "$1" ]; then
  dir="$(pwd)"
else
  dir="$1"
fi

if is_git_repo "$dir"; then
  output=$(gitmux -cfg "$XDG_CONFIG_HOME/gitmux/gitmux.conf" "$dir")
elif git --git-dir="$dir/.bare" rev-parse --git-dir &>/dev/null 2>&1; then
  # Bare worktree parent directory — no active branch, show a static indicator
  output="#[fg=white,bold]_bare_#[none]"
else
  output=""
fi

if [[ -n "$output" ]]; then
  pr_url=$(cd "$dir" && ghpr -e 2>/dev/null) || pr_url=""
  if [[ -n "$pr_url" ]]; then
    pr_number="${pr_url##*/}"
    if [[ -n "$pr_number" ]]; then
      _bg=$(tmux show-option -gqv "@thm_surface_0" 2>/dev/null)
      _bg_fmt="${_bg:+bg=${_bg},}"
      output="$output#[${_bg_fmt}fg=colour244] PR #[${_bg_fmt}fg=colour220]#${pr_number}#[none]"
    fi
  fi
fi

echo "$output"
