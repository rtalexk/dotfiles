#!/usr/bin/env bash

echo_only=false

for arg in "$@"; do
  [[ "$arg" == "--echo" || "$arg" == "-e" ]] && echo_only=true
done

url=$(gh pr view --json url -q '.url' 2>/dev/null)

if [[ -z "$url" ]]; then
  echo "No open PR for current branch"
  exit 1
fi

if $echo_only; then
  echo "$url"
else
  open "$url"
fi
