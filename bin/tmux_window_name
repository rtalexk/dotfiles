#!/usr/bin/env ruby

cmd = ARGV[0].to_s.downcase.split("/").last

# INFO: Claude, Lazygit, Nvim & GH Dash icons must be unique.
icon = case cmd
when "nvim"                           then "¾░İĞ"
when "lazygit"                        then "´çÆ"
when "gh-dash"                        then "´äô"
when "gh"                             then "¯¼Ç"
when "vim", "vi"                      then "¾░à®"
when "git"                            then "´çô"
when "ruby", "irb", "pry"             then "¯ê¥"
when "node", "npm", "npx", "bun"      then "¯┤ı"
when "python", "python3", "ipython"   then "¯£╝"
when "go", "air"                      then "¯İğ"
when "rust", "cargo"                  then "¯Ş¿"
when "docker"                         then "´êş"
when "kubectl", "k9s"                 then "¾▒â¥"
when "htop", "btop", "top"            then "¾░¿ç"
when "ssh"                            then "¾░úÇ"
when "psql", "mysql", "sqlite3"       then "´çÇ"
when "fzf"                            then "¯░ı"
when "bash", "zsh", "fish", "sh"      then "´Æë"
when "man"                            then "¯¬ñ"
else                                       "´Æë"
end

puts icon
