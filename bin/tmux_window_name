#!/usr/bin/env ruby

cmd = ARGV[0].to_s.downcase.split("/").last

icon = case cmd
when "nvim", "vim", "vi"              then "¾░ÿª"   # Neovim
when "lazygit", "git"                 then "´çô"   # Git
when "gh", "gh-dash"                  then "´äô"   # GitHub
when "ruby", "irb", "pry"             then "¯ê¥"   # Ruby gem
when "node", "npm", "npx", "bun"      then "¯┤ì"   # Node.js
when "python", "python3", "ipython"   then "¯£╝"   # Python
when "go", "air"                      then "¯ÿº"   # Go gopher
when "rust", "cargo"                  then "¯×¿"   # Rust
when "docker"                         then "´êƒ"   # Docker
when "kubectl", "k9s"                 then "¾▒â¥"   # Kubernetes
when "htop", "btop", "top"            then "¾░¿ç"   # Activity monitor
when "ssh"                            then "¾░úÇ"   # Remote
when "psql", "mysql", "sqlite3"       then "´çÇ"   # Database
when "fzf"                            then "¯░ì"   # Search
when "bash", "zsh", "fish", "sh"      then "´Æë"   # Shell
when "man"                            then "¯¬ñ"   # Book
else                                       "´Æë"   # Default shell
end

puts icon
