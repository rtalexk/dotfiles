#!/usr/bin/env ruby

parts  = ARGV[0].to_s.downcase.split
cmd    = (parts[0] || "").split("/").last
subcmd = parts[1]

# INFO: Claude, Lazygit, Nvim & GH Dash icons must be unique.
icon = if cmd == "alx"
  case subcmd
  when "brain" then "¯èî"
  when "todo"  then "´æ×"
  else              "´Æë"
  end
else
  case cmd
  when "nvim"                           then "¾░ÿª"
  when "lazygit"                        then "¯½¢"
  when "gh-dash"                        then "´äô"
  when "gh"                             then "¯¼Ç"
  when "vim", "vi"                      then "¾░à®"
  when "git"                            then "´çô"
  when "ruby", "irb", "pry"             then "¯ê¥"
  when "node", "npm", "npx", "bun"      then "¯┤ì"
  when "python", "python3", "ipython"   then "¯£╝"
  when "go", "air"                      then "¯ÿº"
  when "rust", "cargo"                  then "¯×¿"
  when "docker"                         then "´êƒ"
  when "kubectl", "k9s"                 then "¾▒â¥"
  when "htop", "btop", "top"            then "¾░¿ç"
  when "ssh"                            then "¾░úÇ"
  when "psql", "mysql", "sqlite3"       then "´çÇ"
  when "fzf"                            then "¯░ì"
  when "bash", "zsh", "fish", "sh"      then "´Æë"
  when "man"                            then "¯¬ñ"
  else                                       "´Æë"
  end
end

puts icon
